---
import { Image } from "astro:assets";
import portrait from "../assets/images/daniel_osorio.png";
import BaseLayout from "../layouts/BaseLayout.astro";
import SocialLinks from "../components/SocialLinks.astro";
import { withBase } from "../utils/paths";
---

<BaseLayout
  title="Daniel Osório — Data Scientist"
  description="Data scientist working on pricing, experimentation, and customer decision systems, with a background in academic research in cell biology."
>

<!-- HERO -->
<section class="mt-10 md:mt-16 grid grid-cols-1 gap-10 md:grid-cols-[2fr_1fr]">

  <!-- LEFT COLUMN -->
  <div class="border-l-2 border-accent pl-5 md:pl-6">

    <h1 class="font-sans text-3xl font-semibold tracking-tight leading-tight">
      Daniel Osório
    </h1>

    <p class="mt-4 font-sans text-lg md:text-xl leading-relaxed text-slate-800 max-w-2xl">
      Data scientist working on pricing, experimentation, and customer decision systems.
    </p>

    <p class="mt-4 font-sans text-base leading-relaxed text-slate-600 max-w-2xl">
      I focus on turning analytical work into decisions that can be explained,
      measured, and improved in real operating environments.
    </p>

    <ul class="mt-6 flex flex-wrap gap-x-6 gap-y-2 text-sm font-sans text-slate-500">
      <li>Pricing</li>
      <li>Marketing targeting</li>
      <li>Experimentation</li>
      <li>Customer experience</li>
      <li>Decision systems</li>
    </ul>

    <div class="mt-6">
      <SocialLinks />
    </div>

  </div>

  <!-- RIGHT COLUMN -->
    <div class="border-l-2 border-slate-200 pl-5 md:pl-6 pt-2 md:pt-14">

    <!-- PHOTO -->
    <Image
      src={portrait}
      alt="Portrait of Daniel Osório"
      class="h-24 w-24 md:h-32 md:w-32 rounded-md object-cover grayscale mb-6"
      width="128"
      height="128"
    />

    <!-- QUOTE -->
    <blockquote class="font-serif text-lg md:text-xl italic leading-relaxed text-slate-600">
      “All models are wrong, but some are useful.”
    </blockquote>

    <p class="mt-3 text-sm font-sans text-slate-400">
      George Box
    </p>

  </div>

</section>

  <!-- POSITIONING -->
  <section class="mt-12 border-t border-slate-200 pt-12">
    <div class="grid gap-8 md:grid-cols-3">
      <div>
        <p class="font-sans text-xs font-semibold uppercase tracking-[0.16em] text-slate-500">
          What I bring
        </p>
      </div>

      <div class="md:col-span-2">
        <ul class="space-y-4 font-sans text-slate-800">
          <li>
            Analytical work tied to business decisions rather than model output alone.
          </li>
          <li>
            Experience spanning pricing, targeting, performance measurement, and customer analysis.
          </li>
          <li>
            A research background that brings rigor, uncertainty awareness, and careful interpretation.
          </li>
        </ul>
      </div>
    </div>
  </section>

  <!-- CURRENT WORK -->
  <section class="mt-12">
    <h2 class="font-sans text-xl font-semibold">
      Current work
    </h2>

    <div class="mt-8 font-sans leading-relaxed text-slate-800 max-w-3xl">
      <p>
        I work on applied data science problems in personal finance,
        supporting pricing, marketing targeting, and customer experience
        decisions through experimentation and analytical modeling.
      </p>

      <p class="mt-4">
        My focus is translating analytical results into decisions that can
        be explained, monitored, and continuously improved in production
        environments.
      </p>
    </div>
  </section>

  <!-- RESEARCH BACKGROUND -->
  <section class="mt-12">
    <h2 class="font-sans text-xl font-semibold">
      Research background
    </h2>

    <div class="mt-8 font-sans leading-relaxed text-slate-800 max-w-3xl">
      <p>
        Before moving into industry, I spent almost two decades in academic
        research studying cytoskeleton dynamics and actomyosin contractility,
        working in environments where data analysis, microscopy systems, and
        computational tools were central to experimentation.
      </p>

      <p class="mt-4">
        This experience shaped how I approach problems today through
        hypothesis-driven thinking, careful interpretation of results, and
        awareness of uncertainty and experimental limitations.
      </p>
    </div>
  </section>

  <!-- EXPLORE -->
  <section class="mt-12 border-t border-slate-200 pt-12">
    <h2 class="font-sans text-lg font-semibold">
      Explore
    </h2>

    <p class="mt-3 max-w-2xl font-sans leading-relaxed text-slate-600">
      Selected work from applied data science projects and previous academic research.
    </p>

    <ul class="mt-5 space-y-3 font-sans max-w-xl">
      <li class="flex items-start gap-2">
        <span class="pt-1 text-slate-400">•</span>
        <a href={withBase("/projects")} class="text-slate-700 hover:text-accent hover:underline underline-offset-4">
          Data science & applied ML projects
        </a>
      </li>

      <li class="flex items-start gap-2">
        <span class="pt-1 text-slate-400">•</span>
        <a href={withBase("/publications")} class="text-slate-700 hover:text-accent hover:underline underline-offset-4">
          Academic publications and research output
        </a>
      </li>
    </ul>
  </section>

</BaseLayout>
